  "version": "0.1.0",
  "description": "GRC Flow - Knowledge Base and Process Flow Generation System",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "node dist/database/migrations.js",
    "db:seed": "node dist/database/seeds.js",
