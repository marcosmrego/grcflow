# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=postgres
DB_SCHEMA=grc_flow

# Server
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Anthropic (for AI integration)
ANTHROPIC_API_KEY=your_key_here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# AIOS usage tracking (optional — leave empty to disable)
AIOS_API_URL=https://aios.expansao-ai.com.br
AIOS_TRACK_KEY=

# JWT (required in production — server refuses to start without it)
JWT_SECRET=your_secret_here

# CORS (required in production — restrict to the frontend's real origin)
CORS_ORIGIN=https://your-frontend-domain.com

# SMTP para envio de e-mails (faturas, notificações)
# Deixe SMTP_HOST em branco para desabilitar envio real (ações ainda são registradas no banco)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="GRC Flow" <noreply@grcflow.com.br>

# Seed inicial (somente usados na primeira execução das migrations, quando a tabela
# ainda está vazia — deixe em branco para não criar nenhum admin automaticamente)
SEED_ADMIN_PASSWORD=
SEED_PLATFORM_ADMIN_PASSWORD=
